<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Label?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.gestionap.controller.HabitacionesController"
      spacing="10"
      style="-fx-padding: 20; -fx-background-color: #ecf0f1;">

    <Label text="Habitaciones"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <TableView fx:id="tablaHabitaciones" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"     text="ID"      prefWidth="60"/>
            <TableColumn fx:id="colNumero" text="Número"  prefWidth="80"/>
            <TableColumn fx:id="colPrecio" text="Precio"  prefWidth="100"/>
            <TableColumn fx:id="colEstado" text="Estado"  prefWidth="120"/>
            <TableColumn fx:id="colPiso"   text="Piso"    prefWidth="200"/>
        </columns>
    </TableView>

</VBox>
